# ⚠️  DEV ONLY — do NOT commit real credentials.
# Generate this file locally from admin_release.props.example:
#   cp infra/kafka/admin_release.props.example infra/kafka/admin_release.props
#   # then fill in the real KAFKA_ADMIN_PASSWORD from your secrets manager
#
# Production: switch to security.protocol=SASL_SSL and load credentials from
# a secrets manager (e.g. Vault, AWS Secrets Manager) instead of hardcoding.
security.protocol=SASL_PLAINTEXT
sasl.mechanism=PLAIN
sasl.jaas.config=org.apache.kafka.common.security.plain.PlainLoginModule required username="admin" password="REPLACE_WITH_KAFKA_ADMIN_PASSWORD";
