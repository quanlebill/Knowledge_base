{
  "realm": "aeroflow",
  "enabled": true,
  "displayName": "AeroFlow Platform",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespan": 900,
  "clients": [
    {
      "clientId": "aeroflow-frontend",
      "name": "AeroFlow Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:3000"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "aeroflow-backend",
      "name": "AeroFlow Backend (Kong)",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "aeroflow-backend-secret-change-in-prod"
    },
    {
      "clientId": "aeroflow-admin",
      "name": "AeroFlow Admin (python-keycloak)",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "aeroflow-admin-secret-change-in-prod"
    }
  ],
  "roles": {
    "realm": [
      { "name": "platform-admin",    "description": "Full platform sovereignty" },
      { "name": "ai-engineer",       "description": "AI runtime and deployment access" },
      { "name": "business-operator", "description": "Business dashboards and reports" },
      { "name": "executive-viewer",  "description": "Read-only executive view" }
    ]
  },
  "users": [
    {
      "username": "platform-admin",
      "email": "admin@aeroflow.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "Admin@1234", "temporary": false }
      ],
      "realmRoles": ["platform-admin"]
    },
    {
      "username": "ai-engineer",
      "email": "engineer@aeroflow.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "Engineer@1234", "temporary": false }
      ],
      "realmRoles": ["ai-engineer"]
    }
  ],
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false
    }
  ],
  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';"
  }
}
