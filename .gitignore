# Ignore everything
.claude/

data_agent.egg-info/

dist/
.env*
!.env.example
.env.local
.idea/
node_modules/
__pycache__/
*.pyc
coverage/
.DS_Store
*.log

# Claude Code local settings — contains per-developer tool permissions; not shared
.claude/settings.local.json

# Generated cert files — run infra/certs/gen-certs.sh to create locally
infra/certs/*.key
infra/certs/*.crt
infra/certs/*.csr
infra/certs/*.srl

# Kafka credential files — contain real passwords; use *.example templates instead
infra/kafka/kafka-broker-jaas.config
infra/kafka/admin_release.props
infra/kafka/rw.props
