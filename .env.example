# --- Infrastructure (docker-compose) ---
POSTGRES_DB=dataagent
POSTGRES_USER=admin
POSTGRES_PASSWORD=
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://admin:<password>@localhost:5432/dataagent
MONGODB_URL=mongodb://localhost:27017/dataagent
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
OPENBAO_IMAGE=openbao/openbao:latest
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable

# --- DB RBAC ---
# runtime_writer chỉ có INSERT/SELECT trên conversations, messages, agent_traces
RUNTIME_DB_PASSWORD=
RUNTIME_DB_URL=postgresql+asyncpg://runtime_writer:<password>@localhost:5432/dataagent

# --- Vector DB ---
QDRANT_URL=http://localhost:6333
EMBEDDING_DIM=1536

# --- LiteLLM Gateway ---
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=
LITELLM_MASTER_KEY=

# --- LLM Provider ---
LLM_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- Knowledge Base (set khi KB service sẵn sàng) ---
KB_ENDPOINT=
KB_MODE=hybrid
KB_TOP_K=10
KB_MAX_DEPTH=3

# --- App ---
DEV_SYSTEM_PROMPT=You are a helpful assistant for GTEL platform.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
DEV_TENANT_ID=
DEV_AGENT_VER_ID=
DEV_AGENT_ID=
MEMORY_RETENTION_DAYS=90
MEMORY_CLEANUP_BATCH_SIZE=1000

# --- Langfuse (observability) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME
LANGFUSE_SALT=CHANGE_ME

# --- Langfuse default account (tạo tự động khi container khởi động lần đầu) ---
LANGFUSE_INIT_EMAIL=admin@example.com
LANGFUSE_INIT_PASSWORD=CHANGE_ME
LANGFUSE_INIT_NAME=Admin
LANGFUSE_INIT_ORG=GTEL
LANGFUSE_INIT_PROJECT=data-agent
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-change-me

# ── Keycloak (frontend) ─────────────────────────────────────
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=aeroflow
VITE_KEYCLOAK_CLIENT=aeroflow-frontend

# ── Kafka service passwords ──────────────────────────────────
# Must match the passwords in infra/kafka/kafka-broker-jaas.config.
# Copy this file to .env and fill in real values — never commit .env.
KAFKA_ADMIN_PASSWORD=CHANGE_ME
AUDIT_BRIDGE_KAFKA_PASSWORD=CHANGE_ME
AUDIT_CONSUMER_KAFKA_PASSWORD=CHANGE_ME
RELEASE_WORKER_KAFKA_PASSWORD=CHANGE_ME
CI_SERVICE_KAFKA_PASSWORD=CHANGE_ME
DRIFT_DETECTOR_KAFKA_PASSWORD=CHANGE_ME
SCAN_RUNNER_KAFKA_PASSWORD=CHANGE_ME
NOTIFICATION_CONSUMER_KAFKA_PASSWORD=CHANGE_ME
