{
  "permissions": {
    "allow": [
      "PowerShell(Get-ChildItem -Recurse -Force)",
      "PowerShell(Select-Object FullName)",
      "Bash(head -100)",
      "Bash(curl -s http://localhost:4000/health)",
      "Bash(curl -s http://localhost:4000/health -H \"Authorization: Bearer sk-dev\")",
      "Bash(curl -s -X POST http://localhost:8001/api/conversations/run -H 'Content-Type: application/json' -d '{\"query\":\"hi\",\"agent_id\":\"dev\",\"messages\":[]}' --max-time 15)",
      "Bash(curl -N -X POST http://localhost:8001/api/conversations/run -H 'Content-Type: application/json' -d '{\"query\":\"hi\",\"agent_id\":\"dev\",\"messages\":[]}' --max-time 20)",
      "Bash(echo \"EXIT: $?\")"
    ]
  }
}
